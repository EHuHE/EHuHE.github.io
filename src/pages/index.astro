---
import { getCollection } from "astro:content";
import BaseLayout from "../components/BaseLayout.astro";
import { formatDate, getFeaturedPosts } from "../lib/content";
import { toPostSummary } from "../lib/entries";
import { siteProfile } from "../lib/site";
import { withBasePath } from "../lib/url";

const postEntries = await getCollection("posts");
const selectedPosts = getFeaturedPosts(postEntries.map(toPostSummary), 3);

const academicLinks = [
  {
    label: siteProfile.email,
    labelZh: siteProfile.email,
    meta: "Email",
    metaZh: "邮箱",
    href: `mailto:${siteProfile.email}`,
  },
  {
    label: "GitHub",
    labelZh: "GitHub",
    meta: "Code & projects",
    metaZh: "代码与项目",
    href: siteProfile.githubUrl,
  },
  {
    label: "Homepage",
    labelZh: "主页",
    meta: "Public academic identity",
    metaZh: "公开学术身份",
    href: siteProfile.homepageUrl,
  },
];
---

<BaseLayout title="Home" description={siteProfile.description} bodyClass="minimal-home">
  <section class="home-intro" aria-labelledby="profile-name">
    <div class="shell home-intro-grid">
      <figure class="home-avatar">
        <img
          src={withBasePath("/images/he-hu-cartoon-voxel-portrait.jpg")}
          alt="AI-generated voxel portrait of He Hu"
          title="AI-generated voxel portrait"
          width="1200"
          height="1200"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>

      <div class="home-intro-copy">
        <p class="home-role">
          <span class="i18n-en">Graduate student · AI safety & cybersecurity</span>
          <span class="i18n-zh" lang="zh-CN">研究生 · AI 安全与网络空间安全</span>
        </p>
        <h1 id="profile-name">{siteProfile.name}</h1>
        <p class="home-chinese-name" lang="zh-CN">{siteProfile.chineseName}</p>
        <p class="home-claim i18n-en">{siteProfile.headline}</p>
        <p class="home-claim i18n-zh" lang="zh-CN">{siteProfile.headlineZh}</p>
        <p class="home-bio">
          <span class="i18n-en">{siteProfile.shortBio}</span>
          <span class="i18n-zh" lang="zh-CN">{siteProfile.shortBioZh}</span>
        </p>
        <div class="home-academic-meta">
          <p class="home-affiliation">
            <span class="i18n-en">{siteProfile.institution}</span>
            <span class="i18n-zh" lang="zh-CN">{siteProfile.institutionZh}</span>
          </p>
          <p class="home-program">
            <span class="i18n-en">{siteProfile.program}</span>
            <span class="i18n-zh" lang="zh-CN">{siteProfile.programChineseName}</span>
          </p>
        </div>

        <div class="home-actions">
          <a href={withBasePath("/posts/")}>
            <span class="i18n-en">Read notes</span>
            <span class="i18n-zh" lang="zh-CN">阅读笔记</span>
            <span class="link-arrow" aria-hidden="true">↗</span>
          </a>
          <a href={`mailto:${siteProfile.email}`}>
            <span class="i18n-en">Email me</span>
            <span class="i18n-zh" lang="zh-CN">给我发邮件</span>
            <span class="link-arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-focus" aria-labelledby="research-focus-heading">
    <div class="shell home-section-grid">
      <header class="home-section-heading">
        <p class="home-section-index">01</p>
        <h2 id="research-focus-heading">
          <span class="i18n-en">Research focus</span>
          <span class="i18n-zh" lang="zh-CN">研究方向</span>
        </h2>
      </header>

      <ul class="focus-list">
        {
          siteProfile.currentFocus.map((item) => (
            <li>
              <h3>
                <span class="i18n-en">{item.title}</span>
                <span class="i18n-zh" lang="zh-CN">{item.titleZh}</span>
              </h3>
              <p>
                <span class="i18n-en">{item.description}</span>
                <span class="i18n-zh" lang="zh-CN">{item.descriptionZh}</span>
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="home-section home-notes" aria-labelledby="selected-notes-heading">
    <div class="shell home-section-grid">
      <header class="home-section-heading">
        <p class="home-section-index">02</p>
        <h2 id="selected-notes-heading">
          <span class="i18n-en">Selected research notes</span>
          <span class="i18n-zh" lang="zh-CN">精选研究笔记</span>
        </h2>
        <a class="home-section-link" href={withBasePath("/posts/")}>
          <span class="i18n-en">All notes</span>
          <span class="i18n-zh" lang="zh-CN">全部笔记</span>
          <span class="link-arrow" aria-hidden="true">↗</span>
        </a>
      </header>

      <div class="selected-note-list">
        {
          selectedPosts.map((post) => (
            <article>
              <time datetime={post.pubDate.toISOString()}>{formatDate(post.pubDate)}</time>
              <div>
                <h3><a href={withBasePath(`/posts/${post.slug}/`)}>{post.title}</a></h3>
                <p>{post.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="home-section home-details" aria-labelledby="contact-profiles-heading">
    <div class="shell home-section-grid">
      <header class="home-section-heading">
        <p class="home-section-index">03</p>
        <h2 id="contact-profiles-heading">
          <span class="i18n-en">Contact & profiles</span>
          <span class="i18n-zh" lang="zh-CN">联系与公开主页</span>
        </h2>
      </header>

      <div>
        <ul class="academic-link-list">
          {
            academicLinks.map((link) => (
              <li>
                <span>
                  <span class="i18n-en">{link.meta}</span>
                  <span class="i18n-zh" lang="zh-CN">{link.metaZh}</span>
                </span>
                <a href={link.href}>
                  <span class="i18n-en">{link.label}</span>
                  <span class="i18n-zh" lang="zh-CN">{link.labelZh}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <p class="academic-status">
          <span class="i18n-en">{siteProfile.publicationsNotice}</span>
          <span class="i18n-zh" lang="zh-CN">{siteProfile.publicationsNoticeZh}</span>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
