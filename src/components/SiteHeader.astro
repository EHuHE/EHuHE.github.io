---
import { GraduationCap, Menu, Moon, Sun, X } from "lucide-astro";
import { navigationItems, siteProfile } from "../lib/site";
import { withBasePath, withoutBasePath } from "../lib/url";

const currentPath = withoutBasePath(Astro.url.pathname);

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href={withBasePath("/")} aria-label={`${siteProfile.name} homepage`}>
      <span class="brand-mark" aria-hidden="true">
        <GraduationCap size={21} stroke-width={2.1} />
      </span>
      <span>
        <strong>{siteProfile.name}</strong>
        <small>{siteProfile.label}</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {
        navigationItems.map((item) => (
          <a href={withBasePath(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <button class="icon-button theme-toggle" type="button" aria-label="Switch to dark theme" data-theme-toggle>
        <span class="theme-icon theme-icon-light" aria-hidden="true">
          <Sun size={18} />
        </span>
        <span class="theme-icon theme-icon-dark" aria-hidden="true">
          <Moon size={18} />
        </span>
      </button>
      <button
        class="icon-button mobile-menu-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-menu-toggle
      >
        <span data-menu-open-icon aria-hidden="true"><Menu size={20} /></span>
        <span data-menu-close-icon aria-hidden="true" hidden><X size={20} /></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" data-testid="mobile-nav" data-mobile-nav hidden>
    {
      navigationItems.map((item) => (
        <a href={withBasePath(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
