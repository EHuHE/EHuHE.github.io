---
import { ArrowRight } from "lucide-astro";
import type { PostSummary } from "../lib/content";
import { formatDate } from "../lib/content";
import { withBasePath } from "../lib/url";

interface Props {
  posts: PostSummary[];
  compact?: boolean;
}

const { posts, compact = false } = Astro.props;
---

<div class:list={["post-table", { compact }]} role="table" aria-label="Post list">
  <div class="post-row post-row-head" role="row">
    <span role="columnheader">Title</span>
    <span role="columnheader">Tags</span>
    <span role="columnheader">Date</span>
  </div>
  {
    posts.map((post) => (
      <article
        class="post-row"
        role="row"
        data-testid="post-row"
        data-tags={post.tags.join("|")}
        data-search={[post.title, post.description, ...post.tags].join(" ")}
      >
        <div role="cell">
          <a class="post-title" href={withBasePath(`/posts/${post.slug}/`)}>
            <span>{post.title}</span>
            <ArrowRight size={16} aria-hidden="true" />
          </a>
        </div>
        <div class="tag-list" role="cell" aria-label={`${post.title} tags`}>
          {post.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <time role="cell" datetime={post.pubDate.toISOString()}>{formatDate(post.pubDate)}</time>
      </article>
    ))
  }
</div>
