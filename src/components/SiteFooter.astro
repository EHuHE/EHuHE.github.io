---
import { siteProfile } from "../lib/site";
import { withBasePath } from "../lib/url";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell footer-minimal">
    <p>
      © {year} {siteProfile.name}.
      <span class="i18n-en">Research notes in progress.</span>
      <span class="i18n-zh" lang="zh-CN">持续更新研究笔记。</span>
    </p>
    <nav class="footer-text-links" aria-label="Footer links">
      <a href={siteProfile.githubUrl}>GitHub</a>
      <a href={`mailto:${siteProfile.email}`}>
        <span class="i18n-en">Email</span>
        <span class="i18n-zh" lang="zh-CN">邮箱</span>
      </a>
      <a href={withBasePath(siteProfile.rssUrl)}>RSS</a>
      <a href="#top">
        <span class="i18n-en">Top</span>
        <span class="i18n-zh" lang="zh-CN">顶部</span>
      </a>
    </nav>
  </div>
</footer>
