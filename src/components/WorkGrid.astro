---
import IconFont from "./IconFont.astro";
import type { WorkSummary } from "../lib/entries";
import { withBasePath } from "../lib/url";

interface Props {
  works: WorkSummary[];
}

const { works } = Astro.props;
const icons = {
  project: "ai-design",
  resource: "file-info",
  note: "project-log",
};

const typeLabels = {
  project: { en: "Project", zh: "项目" },
  resource: { en: "Resource", zh: "资源" },
  note: { en: "Note", zh: "笔记" },
};
---

<div class="work-grid">
  {
    works.map((work) => {
      const iconName = icons[work.type];
      const typeLabel = typeLabels[work.type];
      return (
        <article class={`work-card work-card-${work.type}`}>
          <div class="work-visual" aria-hidden="true">
            <span>{work.type === "project" ? "01" : work.type === "resource" ? "02" : "03"}</span>
          </div>
          <div class="work-card-top">
            <span class="entry-icon" aria-hidden="true">
              <IconFont name={iconName} size={22} />
            </span>
            <span class="tag">
              <span class="i18n-en">{typeLabel.en}</span>
              <span class="i18n-zh" lang="zh-CN">{typeLabel.zh}</span>
            </span>
          </div>
          <h3>{work.title}</h3>
          <p>{work.description}</p>
          <div class="tag-list">
            {work.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a href={withBasePath(work.externalUrl ?? "/links/")} target={work.externalUrl?.startsWith("https:") ? "_blank" : undefined} rel={work.externalUrl?.startsWith("https:") ? "noreferrer" : undefined}>
            <span class="i18n-en">View details</span>
            <span class="i18n-zh" lang="zh-CN">查看详情</span>
            <IconFont name="arrow-top-right" size={16} />
          </a>
        </article>
      );
    })
  }
</div>
